{
  "entities": {
    "User": {
      "title": "User",
      "description": "Customer Profile",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp"
        }
      },
      "required": ["email", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin privileges indicator",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        }
      },
      "required": ["userId"]
    },
    "Bag": {
      "title": "Bag",
      "description": "Tote Bag product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "description", "category", "price", "imageUrl", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "bagId": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "bagId", "price", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/admins/{adminId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Admin privileges. Document ID is the admin's User ID"
    },
    "/bags/{bagId}": {
      "schema": { "$ref": "#/entities/Bag" },
      "description": "Tote bags available for purchase"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders placed by customers"
    }
  }
}
